# Copy to .env for local runs. On GitHub, set these as Actions secrets instead.
# NEVER commit the real .env (see .gitignore).

# LLM extraction (30_extract.py). Required for extraction on GitHub/local.
ANTHROPIC_API_KEY=sk-ant-...
# Model id for extraction (override the default if needed).
HWC_EXTRACT_MODEL=claude-haiku-4-5

# Geocoding (40_geocode.py). Amap (高德) web-service key gives the best China
# coverage; leave blank to fall back to Nominatim (OpenStreetMap, rate-limited).
AMAP_KEY=

# Contact email sent to Nominatim per its usage policy (optional but polite).
GEOCODE_CONTACT_EMAIL=
